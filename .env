OPENAI_API_KEY=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
