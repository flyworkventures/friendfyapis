# Core
PORT=3000
JWT_SECRET=key

# Voice streaming feature flag
VOICE_STREAMING_ENABLED=true
VIDEO_CALL_ENABLED=false
VOICE_DEBUG_LOGS=false
TTS_STREAMING_ENABLED=false

# STT provider config
STT_PROVIDER=openai-whisper
VOICE_DEFAULT_LANGUAGE=tr-TR
VOICE_AUDIO_CODEC=pcm16le
VOICE_AUDIO_SAMPLE_RATE=16000
VOICE_AUDIO_CHANNELS=1
VOICE_AUDIO_FRAME_MS=20

# WebRTC transport (opsiyonel)
WEBRTC_ENABLED=false
# JSON array string, örn:
# WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
WEBRTC_ICE_SERVERS=

# Deepgram (streaming STT) - opsiyonel
DEEPGRAM_API_KEY=

# AI pipeline config
# echo | webhook | openai
VOICE_AI_MODE=openai
VOICE_AI_WEBHOOK_URL=

# OpenAI (Whisper + GPT)
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
OPENAI_STT_PROMPT=Turkce konusmayi dogru yaz. Belirsiz sesi uydurma.
OPENAI_STT_TEMPERATURE=0
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_CHAT_TEMPERATURE=0.2
STT_MIN_TRANSCRIPT_CHARS=2
STT_MIN_AUDIO_BYTES=3200
VOICE_VAD_SILENCE_MS=1200

# ElevenLabs TTS (streaming)
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=

# Viseme (rhubarb + ffmpeg)
VISEME_ENABLED=false
VISEME_BLOCKING=true
VISEME_PROVIDER=rhubarb
VISEME_MIN_GAP_SEC=0.04
VISEME_FFMPEG_BIN=ffmpeg
VISEME_RHUBARB_BIN=/opt/rhubarb/rhubarb
